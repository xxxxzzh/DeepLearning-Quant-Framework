   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import Dataset, DataLoader\n",
    "import akshare as ak\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.preprocessing import MinMaxScaler\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 1. 定身咒：保证实验可重复\n",
    "def set_seed(seed=42):\n",
    "    torch.manual_seed(seed)\n",
    "    np.random.seed(seed)\n",
    "    torch.cuda.manual_seed_all(seed)\n",
    "\n",
    "set_seed(42)\n",
    "\n",
    "# ==========================================\n",
    "# 第一部分：真实数据获取与特征工程\n",
    "# ==========================================\n",
    "# 获取沪深300数据\n",
    "df_real = ak.stock_zh_index_daily(symbol=\"sh000300\")\n",
    "df_real = df_real[['date', 'open', 'high', 'low', 'close', 'volume']]\n",
    "\n",
    "# 【新增：外挂特征 MA5】#MA5是过去五天收盘价的平均值\n",
    "df_real['MA5'] = df_real['close'].rolling(window=5).mean()\n",
    "\n",
    "# 【关键：删掉空值】前4天算不出MA5，必须删掉\n",
    "df_real = df_real.dropna().reset_index(drop=True)\n",
    "\n",
    "# 【关键：归一化】神经网络只吃 0-1 之间的数字\n",
    "scaler = MinMaxScaler()\n",
    "cols = ['open', 'high', 'low', 'close', 'volume', 'MA5']\n",
    "df_real[cols] = scaler.fit_transform(df_real[cols])\n",
    "\n",
    "# ==========================================\n",
    "# 第二部分：数据集定义 (Dataset)\n",
    "# ==========================================\n",
    "class StockDataset(Dataset):\n",
    "    def __init__(self, df, window_size=30):\n",
    "        # 我们现在用 3 个特征：close, volume, MA5\n",
    "        self.data = df[['close', 'volume', 'MA5']].values\n",
    "        self.window_size = window_size\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.data) - self.window_size\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        # x: 30天 * 3特征 = 90个数字\n",
    "        x = self.data[idx : idx + self.window_size]\n",
    "        x = torch.tensor(x, dtype=torch.float32).flatten()\n",
    "        \n",
    "        # y: 预测下一天的收盘价\n",
    "        y = self.data[idx + self.window_size, 0] \n",
    "        y = torch.tensor([y], dtype=torch.float32)\n",
    "        \n",
    "        return x, y\n",
    "\n",
    "# ==========================================\n",
    "# 第三部分：模型定义 (90维输入)\n",
    "# ==========================================\n",
    "class SimpleQuantModel(nn.Module):\n",
    "    def __init__(self, input_dim=90): # 这里改成了 90\n",
    "        super().__init__()\n",
    "        self.fc1 = nn.Linear(input_dim, 32)\n",
    "        self.relu = nn.ReLU()\n",
    "        self.fc2 = nn.Linear(32, 1)\n",
    "\n",
    "    def forward(self, x):\n",
    "        x = self.fc1(x)\n",
    "        x = self.relu(x)\n",
    "        return self.fc2(x)\n",
    "\n",
    "# 实例化\n",
    "test_ds = StockDataset(df_real, window_size=30)\n",
    "test_loader = DataLoader(test_ds, batch_size=8, shuffle=False)\n",
    "test_model = SimpleQuantModel(input_dim=90)\n",
    "\n",
    "# ==========================================\n",
    "# 第四部分：训练引擎 (B部分逻辑)\n",
    "# ==========================================\n",
    "criterion = nn.MSELoss()\n",
    "optimizer = optim.Adam(test_model.parameters(), lr=0.001)\n",
    "\n",
    "print(\"🚀 开启真实数据 + MA5 特征训练...\")\n",
    "for epoch in range(10):\n",
    "    test_model.train()\n",
    "    epoch_loss = 0.0\n",
    "    for batch_x, batch_y in test_loader:\n",
    "        optimizer.zero_grad()\n",
    "        pred = test_model(batch_x)\n",
    "        loss = criterion(pred, batch_y)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        epoch_loss += loss.item()\n",
    "    \n",
    "    print(f\"Epoch {epoch+1:02d} | Loss: {epoch_loss/len(test_loader):.6f}\")\n",
    "\n",
    "# ==========================================\n",
    "# 第五部分：可视化验证\n",
    "# ==========================================\n",
    "test_model.eval()\n",
    "with torch.no_grad():\n",
    "    x_sample, y_real = next(iter(test_loader))\n",
    "    y_pred = test_model(x_sample)\n",
    "\n",
    "plt.plot(y_real.numpy(), label='Real Price')\n",
    "plt.plot(y_pred.numpy(), label='Pred Price (with MA5)')\n",
    "plt.legend()\n",
    "plt.title(\"Real vs Pred (MA5 Feature Included)\")\n",
    "plt.show()"
   ]
  },
