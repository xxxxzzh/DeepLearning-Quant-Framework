    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import Dataset, DataLoader\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import random\n",
    "\n",
    "# ==========================================\n",
    "# 第一部分：前置准备\n",
    "# ==========================================\n",
    "\n",
    "# 1. 定身咒\n",
    "def set_seed(seed=42):\n",
    "    random.seed(seed)\n",
    "    np.random.seed(seed)\n",
    "    torch.manual_seed(seed)\n",
    "    torch.cuda.manual_seed_all(seed)\n",
    "    torch.backends.cudnn.deterministic = True\n",
    "    torch.backends.cudnn.benchmark = False\n",
    "\n",
    "set_seed(42)\n",
    "\n",
    "# 2. 造假数据（100天，2个特征）\n",
    "data = np.random.randn(100, 2) \n",
    "df = pd.DataFrame(data, columns=['close', 'volume'])\n",
    "df['date'] = pd.date_range('2020-01-01', periods=100)\n",
    "\n",
    "# 3. 数据集定义（新增了真实标签 y 的获取）\n",
    "class StockDataset(Dataset):\n",
    "    def __init__(self, df, window_size=30):\n",
    "        self.data = df[['close', 'volume']].values\n",
    "        self.window_size = window_size\n",
    "\n",
    "    def __len__(self):\n",
    "        # 留出最后一天作为 y（答案）\n",
    "        return len(self.data) - self.window_size\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        # x: 过去 30 天的数据（展平为 60 维）\n",
    "        x = self.data[idx : idx + self.window_size]\n",
    "        x = torch.tensor(x, dtype=torch.float32).flatten()\n",
    "        \n",
    "        # y: 第 31 天的 close 值作为预测目标\n",
    "        y = self.data[idx + self.window_size, 0] \n",
    "        y = torch.tensor([y], dtype=torch.float32)\n",
    "        \n",
    "        return x, y\n",
    "\n",
    "# 4. 模型定义（保持 60 维输入）\n",
    "class SimpleQuantModel(nn.Module):\n",
    "    def __init__(self, input_dim=60):\n",
    "        super().__init__()\n",
    "        self.fc1 = nn.Linear(input_dim, 32)\n",
    "        self.relu = nn.ReLU()\n",
    "        self.fc2 = nn.Linear(32, 1)\n",
    "\n",
    "    def forward(self, x):\n",
    "        x = self.fc1(x)\n",
    "        x = self.relu(x)\n",
    "        return self.fc2(x)\n",
    "\n",
    "# 5. 实例化模型与加载器\n",
    "test_model = SimpleQuantModel(input_dim=60)\n",
    "test_ds = StockDataset(df, window_size=30)\n",
    "test_loader = DataLoader(test_ds, batch_size=8, shuffle=False)\n",
    "\n",
    "\n",
    "# ==========================================\n",
    "# 第二部分：试车场（新增的训练引擎）\n",
    "# ==========================================\n",
    "\n",
    "# 1. 请出“裁判”和“教练”\n",
    "criterion = nn.MSELoss()  # 均方误差（越低，说明模型猜的越准）\n",
    "optimizer = optim.Adam(test_model.parameters(), lr=0.001)  # 学习率 0.001\n",
    "\n",
    "# 2. 训练大循环\n",
    "epochs = 15  # 让模型学 15 遍\n",
    "\n",
    "print(\"开始训练模型...\\n\")\n",
    "\n",
    "for epoch in range(epochs):\n",
    "    test_model.train()  # 开启训练模式\n",
    "    epoch_loss = 0.0\n",
    "    \n",
    "    # 批处理循环\n",
    "    for batch_x, batch_y in test_loader:\n",
    "        \n",
    "        optimizer.zero_grad()            # 1. 清空旧梯度\n",
    "        pred = test_model(batch_x)       # 2. 模型前向预测\n",
    "        loss = criterion(pred, batch_y)  # 3. 裁判计算误差\n",
    "        \n",
    "        loss.backward()                  # 4. 误差反向传播，看看具体是哪一层的哪个参数导致了这次丢分，计算出修改方向\n",
    "        optimizer.step()                 # 5. 教练更新权重\n",
    "        # ----------------------\n",
    "        \n",
    "        epoch_loss += loss.item()\n",
    "        \n",
    "    # 计算每一轮的平均误差并打印\n",
    "    avg_loss = epoch_loss / len(test_loader)\n",
    "    print(f\"Epoch {epoch+1:02d}/{epochs} | Loss: {avg_loss:.6f}\")\n",
    "\n",
    "print(\"\\n训练完成！仔细看上面的 Loss 是不是在慢慢变小？\")"
   ]
  },
